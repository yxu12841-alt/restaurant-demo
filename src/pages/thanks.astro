---
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Thank you | The Harbour Table</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
  </head>

  <body class="flex min-h-screen items-center justify-center bg-stone-950 px-6 text-stone-100">
    <main class="max-w-xl rounded-3xl border border-stone-800 bg-stone-900 p-10 text-center">
      <p class="text-sm uppercase tracking-[0.3em] text-amber-300">
        Request sent
      </p>

      <h1 class="mt-4 text-4xl font-semibold">
        Thank you.
      </h1>

      <p class="mt-4 text-stone-300">
        Your reservation request has been received. We will contact you shortly to confirm.
      </p>

      <a
        href="/"
        class="mt-8 inline-block rounded-full bg-amber-300 px-6 py-3 font-semibold text-stone-950"
      >
        Back to home
      </a>
    </main>
  </body>
</html>
